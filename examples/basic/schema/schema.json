{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-rspyts": {
    "version": "0.1.0",
    "crate": "basic-example",
    "manifestHash": "sha256:9afd7526528dd6aaa6e61069145dcecf91869613de17ecbacdced9138e551485"
  },
  "$defs": {
    "BinaryPacket": {
      "description": "Binary values and owned numeric buffers nested in ordinary data.",
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/PacketId"
        },
        "payload": {
          "description": "Opaque bytes, distinct from a numeric `u8` buffer on the wire.",
          "type": "object",
          "properties": {
            "__rspyts_buf__": {
              "type": "object",
              "properties": {
                "off": {
                  "type": "integer",
                  "minimum": 0
                },
                "len": {
                  "type": "integer",
                  "minimum": 0
                },
                "dt": {
                  "const": "bytes"
                }
              },
              "required": [
                "off",
                "len",
                "dt"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "__rspyts_buf__"
          ],
          "additionalProperties": false
        },
        "samples": {
          "description": "An aligned floating-point buffer.",
          "type": "object",
          "properties": {
            "__rspyts_buf__": {
              "type": "object",
              "properties": {
                "off": {
                  "type": "integer",
                  "minimum": 0
                },
                "len": {
                  "type": "integer",
                  "minimum": 0
                },
                "dt": {
                  "const": "f64"
                }
              },
              "required": [
                "off",
                "len",
                "dt"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "__rspyts_buf__"
          ],
          "additionalProperties": false
        },
        "chunks": {
          "description": "Buffers can appear inside lists.",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "__rspyts_buf__": {
                "type": "object",
                "properties": {
                  "off": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "len": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "dt": {
                    "const": "i16"
                  }
                },
                "required": [
                  "off",
                  "len",
                  "dt"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "__rspyts_buf__"
            ],
            "additionalProperties": false
          }
        },
        "channels": {
          "description": "Buffers can also appear inside string-keyed maps.",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "__rspyts_buf__": {
                "type": "object",
                "properties": {
                  "off": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "len": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "dt": {
                    "const": "u8"
                  }
                },
                "required": [
                  "off",
                  "len",
                  "dt"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "__rspyts_buf__"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "id",
        "payload",
        "samples",
        "chunks",
        "channels"
      ],
      "additionalProperties": false
    },
    "ExactNumbers": {
      "description": "Exact integers in plain, tuple, optional, and list positions.",
      "type": "object",
      "properties": {
        "signed": {
          "type": "string",
          "format": "int64",
          "pattern": "^(?:0|-?[1-9][0-9]*)$",
          "x-rspyts-minimum": "-9223372036854775808",
          "x-rspyts-maximum": "9223372036854775807"
        },
        "unsigned": {
          "type": "string",
          "format": "uint64",
          "pattern": "^(?:0|[1-9][0-9]*)$",
          "x-rspyts-minimum": "0",
          "x-rspyts-maximum": "18446744073709551615"
        },
        "transferId": {
          "$ref": "#/$defs/TransferId"
        },
        "pair": {
          "type": "array",
          "prefixItems": [
            {
              "type": "string",
              "format": "int64",
              "pattern": "^(?:0|-?[1-9][0-9]*)$",
              "x-rspyts-minimum": "-9223372036854775808",
              "x-rspyts-maximum": "9223372036854775807"
            },
            {
              "type": "string",
              "format": "uint64",
              "pattern": "^(?:0|[1-9][0-9]*)$",
              "x-rspyts-minimum": "0",
              "x-rspyts-maximum": "18446744073709551615"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "history": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uint64",
                "pattern": "^(?:0|[1-9][0-9]*)$",
                "x-rspyts-minimum": "0",
                "x-rspyts-maximum": "18446744073709551615"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "byName": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "format": "int64",
            "pattern": "^(?:0|-?[1-9][0-9]*)$",
            "x-rspyts-minimum": "-9223372036854775808",
            "x-rspyts-maximum": "9223372036854775807"
          }
        }
      },
      "required": [
        "signed",
        "unsigned",
        "transferId",
        "pair",
        "byName"
      ],
      "additionalProperties": false
    },
    "PacketId": {
      "description": "Stable identifier for a binary packet.\n\nTransparent newtypes remain named in generated APIs and schemas while\nusing the inner integer directly at runtime.",
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295
    },
    "ParsedNumber": {
      "description": "A number parsed from text.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "integer"
            },
            "value": {
              "type": "integer",
              "minimum": -2147483648,
              "maximum": 2147483647
            }
          },
          "required": [
            "type",
            "value"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "decimal"
            },
            "value": {
              "type": "number"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "additionalProperties": false
        }
      ]
    },
    "Rounding": {
      "description": "Rounding strategy for [`round_value`].",
      "type": "string",
      "enum": [
        "up",
        "down",
        "nearest",
        "halfEven"
      ]
    },
    "Summary": {
      "description": "Summary statistics for a list of numbers.",
      "type": "object",
      "properties": {
        "itemCount": {
          "description": "How many values were summarized.",
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "total": {
          "type": "number"
        },
        "average": {
          "type": "number"
        },
        "label": {
          "description": "Optional label passed through untouched.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "source": {
          "description": "Required on the wire even though null is an accepted value.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "itemCount",
        "total",
        "average",
        "source"
      ],
      "additionalProperties": false
    },
    "TransferId": {
      "description": "An exact integer identifier using the ordinary native Rust type.",
      "type": "string",
      "format": "uint64",
      "pattern": "^(?:0|[1-9][0-9]*)$",
      "x-rspyts-minimum": "0",
      "x-rspyts-maximum": "18446744073709551615"
    },
    "TransferState": {
      "description": "A state that can be either tag-only or carry exact data.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "pending"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "complete"
            },
            "sequence": {
              "type": "string",
              "format": "uint64",
              "pattern": "^(?:0|[1-9][0-9]*)$",
              "x-rspyts-minimum": "0",
              "x-rspyts-maximum": "18446744073709551615"
            },
            "receipt": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uint64",
                  "pattern": "^(?:0|[1-9][0-9]*)$",
                  "x-rspyts-minimum": "0",
                  "x-rspyts-maximum": "18446744073709551615"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "type",
            "sequence",
            "receipt"
          ],
          "additionalProperties": false
        }
      ]
    }
  }
}
