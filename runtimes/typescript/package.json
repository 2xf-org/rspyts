{
  "name": "rspyts",
  "version": "0.1.0",
  "description": "TypeScript/WebAssembly runtime for rspyts: define it in Rust, call it in Python and TypeScript.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2xf-org/rspyts.git",
    "directory": "runtimes/typescript"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check:surface": "node scripts/check-public-surface.mjs",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rust",
    "wasm",
    "webassembly",
    "bindings",
    "codegen",
    "ffi"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
